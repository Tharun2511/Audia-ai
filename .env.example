GROQ_API_KEY=your_groq_api_key_here
DATABSE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require&channel_binding=require&uselibpqcompat=true
DEEPGRAM_API_KEY=your_deepgram_api_key_here
SESSION_SECRET=replace_with_a_32_byte_base64_string
GEMINI_API_KEY=your_gemini_api_key_here
# Vercel Blob — enables audio persistence + playback. If unset, transcripts
# still save but the audio is discarded and playback is hidden in the UI.
# Generate via: Vercel dashboard → Storage → Create → Blob → connect to project.
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
